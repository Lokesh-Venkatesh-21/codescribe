FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /codescribe

RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && python -m pip install --upgrade pip

COPY pyproject.toml README.md ./
COPY app ./app
COPY scripts ./scripts

RUN chmod +x /codescribe/scripts/action-entrypoint.sh \
    && python -m pip install ".[local-llm]"

ENTRYPOINT ["/codescribe/scripts/action-entrypoint.sh"]
